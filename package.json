{
  "name": "keikaku-qc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "NRT5/HND2 QC チーム向け 計画実績アプリ",
  "scripts": {
    "bootstrap": "bun scripts/bootstrap-from-xlsx.ts input/qa_plan.xlsx input/air_bins.txt config",
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.main.json && electron .",
    "dev": "concurrently -k \"bun run dev:vite\" \"wait-on http://localhost:5173 && bun run dev:electron\"",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json && node tools/write-cjs-pkg.mjs",
    "build": "bun run build:vite && bun run build:main",
    "package": "bun run build && node tools/package-app.mjs && node tools/copy-config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.scripts.json"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "electron": "^32.2.0",
    "@electron/packager": "^18.3.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
